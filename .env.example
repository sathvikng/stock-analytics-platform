# Copy to backend/.env and fill in values

# --- Database ---
SUPABASE_DB_URL=postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres

# --- LLM Provider ---
# "ollama"      → local Ollama (start with: docker compose --profile ollama up)
# "openrouter"  → OpenRouter API (set OPENROUTER_API_KEY)
LLM_PROVIDER=openrouter

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen3:8b

# OpenRouter (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3-8b

# --- Auth ---
JWT_SECRET=your-strong-random-secret-here
